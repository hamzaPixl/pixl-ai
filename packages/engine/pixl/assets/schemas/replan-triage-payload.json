{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixl:replan-triage-payload",
  "title": "Replan Triage Payload",
  "description": "Structured output from the triage stage of the replan workflow.",
  "type": "object",
  "required": ["decisions", "new_features", "summary"],
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature_id", "action", "reason"],
        "properties": {
          "feature_id": { "type": "string", "minLength": 1 },
          "action": {
            "type": "string",
            "enum": ["keep", "mark_done", "defer", "remove", "reprioritize"]
          },
          "new_priority": {
            "type": ["string", "null"],
            "description": "New priority for reprioritize actions (P0-P3)"
          },
          "reason": { "type": "string", "minLength": 1 },
          "pr_url": {
            "type": ["string", "null"],
            "description": "PR URL for mark_done actions"
          }
        },
        "additionalProperties": false
      },
      "description": "Per-feature triage decisions"
    },
    "new_features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "priority"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "minLength": 1 },
          "epic_id": { "type": ["string", "null"] },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "Feature IDs that this new feature depends on"
          }
        },
        "additionalProperties": false
      },
      "description": "New features suggested by gap analysis"
    },
    "summary": {
      "type": "object",
      "required": ["keep", "mark_done", "defer", "remove", "reprioritize", "new"],
      "properties": {
        "keep": { "type": "integer", "minimum": 0 },
        "mark_done": { "type": "integer", "minimum": 0 },
        "defer": { "type": "integer", "minimum": 0 },
        "remove": { "type": "integer", "minimum": 0 },
        "reprioritize": { "type": "integer", "minimum": 0 },
        "new": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
