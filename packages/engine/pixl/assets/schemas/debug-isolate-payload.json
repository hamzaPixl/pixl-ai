{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixl:debug-isolate-payload",
  "title": "Debug Isolate Payload",
  "description": "Schema for the ISOLATE (triage + binary search) stage output payload.",
  "type": "object",
  "required": ["bug_category", "root_cause_hypothesis"],
  "properties": {
    "bug_category": {
      "type": "string",
      "enum": ["render_state", "data_api", "routing_hydration", "build_tooling", "other"],
      "description": "Classified bug category from triage"
    },
    "root_cause_hypothesis": {
      "type": "string",
      "description": "Hypothesized root cause after isolation"
    },
    "suspect_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files suspected to contain the bug"
    },
    "bisect_result": {
      "type": "string",
      "description": "Result of binary search / bisection"
    },
    "boundary_tests": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Boundary assertions and hardcoded tests performed"
    }
  },
  "additionalProperties": true
}
