{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixl:epic-brief-payload",
  "title": "Epic Brief Payload",
  "description": "Schema for the payload field of an epic/feature refinement stage output.",
  "type": "object",
  "required": ["objective"],
  "properties": {
    "objective": {
      "type": "string",
      "description": "One-paragraph description of what the epic/feature achieves and why"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Technical, timeline, and dependency constraints"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific, testable acceptance criteria"
    },
    "scope_in": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Items explicitly in scope"
    },
    "scope_out": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Items explicitly out of scope"
    },
    "decomposition_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "est_files": { "type": "integer" }
        }
      },
      "description": "Suggested feature breakdown with ordering"
    },
    "risk_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": { "type": "string" },
          "likelihood": { "type": "string" },
          "impact": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      },
      "description": "Identified risks with likelihood, impact, and mitigation"
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Unresolved decisions with recommended defaults"
    }
  },
  "additionalProperties": true
}
