{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixl:decompose-payload",
  "title": "Decompose Stage Payload",
  "description": "Strict schema for epic decomposition payload with plan-only chain metadata.",
  "type": "object",
  "required": ["features", "chain_plan", "validation_summary"],
  "properties": {
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "description",
          "acceptance_criteria",
          "owner",
          "risk_class",
          "estimate_points",
          "dependencies"
        ],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "owner": { "type": "string", "minLength": 1 },
          "risk_class": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "estimate_points": { "type": "integer", "minimum": 1 },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "Feature refs that this feature depends on"
          },
          "suggested_workflow": {
            "type": "string",
            "enum": ["tdd", "simple", "debug"],
            "description": "Recommended workflow for executing this feature"
          },
          "needs_refinement": {
            "type": "boolean",
            "description": "True if this feature should be further decomposed before execution"
          }
        },
        "additionalProperties": false
      }
    },
    "chain_plan": {
      "type": "object",
      "required": ["mode", "nodes", "edges", "waves", "execution_policy"],
      "properties": {
        "mode": { "const": "plan_only" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["feature_ref", "wave", "parallel_group", "depends_on"],
            "properties": {
              "feature_ref": { "type": "string", "minLength": 1 },
              "wave": { "type": "integer", "minimum": 0 },
              "parallel_group": { "type": "integer", "minimum": 0 },
              "depends_on": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "suggested_workflow": {
                "type": "string",
                "enum": ["tdd", "simple", "debug"]
              }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "to": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "execution_policy": {
          "type": "object",
          "required": ["max_parallel", "failure_policy", "stop_on_failure"],
          "properties": {
            "max_parallel": { "type": "integer", "minimum": 1 },
            "failure_policy": { "const": "branch_aware" },
            "stop_on_failure": { "const": false }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "validation_summary": {
      "type": "object",
      "required": ["dag_valid", "cycles_detected", "orphan_nodes", "notes"],
      "properties": {
        "dag_valid": { "type": "boolean" },
        "cycles_detected": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "orphan_nodes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
