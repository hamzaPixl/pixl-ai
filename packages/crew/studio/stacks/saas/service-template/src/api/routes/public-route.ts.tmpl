/**
 * Public route template — unauthenticated endpoints with rate limiting.
 *
 * Use for: contact forms, newsletter signups, public API reads, webhooks.
 * No auth required. Rate limiting prevents abuse.
 */

import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify';
import { z } from 'zod';

// ─── Rate Limiting ──────────────────────────────────────────────────────

interface RateLimitEntry {
  count: number;
  resetAt: number;
}

// NOTE: In-memory store — not shared across instances. For multi-instance
// deployments, replace with Redis or a shared rate-limit service.
const rateLimitStore = new Map<string, RateLimitEntry>();

interface RateLimitConfig {
  windowMs: number;
  maxRequests: number;
}

const DEFAULT_RATE_LIMIT: RateLimitConfig = {
  windowMs: 60_000, // 1 minute
  maxRequests: 10,
};

function rateLimitGuard(config?: Partial<RateLimitConfig>) {
  const { windowMs, maxRequests } = { ...DEFAULT_RATE_LIMIT, ...config };

  return async (request: FastifyRequest, reply: FastifyReply) => {
    const ip = request.ip;
    const now = Date.now();
    const entry = rateLimitStore.get(ip);

    if (entry && entry.resetAt > now) {
      if (entry.count >= maxRequests) {
        reply.status(429).send({
          error: 'Too many requests',
          code: 'RATE_LIMIT_EXCEEDED',
          retryAfter: Math.ceil((entry.resetAt - now) / 1000),
        });
        return;
      }
      entry.count++;
    } else {
      rateLimitStore.set(ip, { count: 1, resetAt: now + windowMs });
    }

    // Cleanup stale entries periodically
    if (rateLimitStore.size > 10_000) {
      for (const [key, val] of rateLimitStore) {
        if (val.resetAt <= now) rateLimitStore.delete(key);
      }
    }
  };
}

