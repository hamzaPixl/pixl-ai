// ─── Spam Filtering ─────────────────────────────────────────────────────

/**
 * Basic honeypot spam detection.
 * Add a hidden field to your form — bots fill it, humans don't.
 */
function isSpam(body: Record<string, unknown>): boolean {
  // Honeypot field — if filled, it's a bot
  if (body._honeypot && String(body._honeypot).length > 0) {
    return true;
  }
  return false;
}

// ─── Public Submission Schema ───────────────────────────────────────────

const PublicSubmissionSchema = z.object({
  // TODO: Define your public submission fields
  // Example for a contact form:
  // name: z.string().min(1).max(200),
  // email: z.string().email(),
  // message: z.string().min(10).max(5000),
  _honeypot: z.string().max(0).optional(), // Honeypot field — must be empty
});

type PublicSubmission = z.infer<typeof PublicSubmissionSchema>;

// ─── Route Registration ─────────────────────────────────────────────────

export function registerPublicRoutes(
  fastify: FastifyInstance,
  deps: {
    // TODO: Inject your repository or service
  },
): void {
  // Public submission (e.g., contact form)
  fastify.post<{ Body: PublicSubmission }>(
    '/public/submit',
    {
      preHandler: [rateLimitGuard({ windowMs: 60_000, maxRequests: 5 })],
    },
    async (request, reply) => {
      const body = PublicSubmissionSchema.parse(request.body);

      if (isSpam(body as Record<string, unknown>)) {
        // Return 200 to not reveal detection to bots
        return { success: true };
      }

      // TODO: Process the submission
      // await deps.submissionRepository.save(submission);

      reply.status(201);
      return { success: true };
    },
  );
}
