{
  "name": "saas-studio",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-based SaaS foundation for AI agent teams",
  "workspaces": ["foundation/*", "examples/*", "tooling/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:architecture": "biome lint .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:transactions": "bun tooling/scripts/check-transactions.js",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "turbo": "^2.8.6",
    "typescript": "^5.9.3",
    "prettier": "^3.8.1",
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.3"
  },
  "packageManager": "bun@1.3.9"
}
