@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* Light mode — Design tokens from archetype */
    --background: 0 0% 100%;
    --foreground: 0 0% 9%;
    --card: 0 0% 100%;
    --card-foreground: 0 0% 9%;
    --popover: 0 0% 100%;
    --popover-foreground: 0 0% 9%;
    --primary: {{PRIMARY_COLOR_HSL}};
    --primary-foreground: 0 0% 100%;
    --secondary: {{SECONDARY_COLOR_HSL}};
    --secondary-foreground: 0 0% 100%;
    --muted: {{SURFACE_COLOR_HSL}};
    --muted-foreground: 0 0% 35%; /* WCAG AA contrast — min 4.5:1 */
    --accent: {{ACCENT_COLOR_HSL}};
    --accent-foreground: {{PRIMARY_COLOR_HSL}};
    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 100%;
    --border: {{SURFACE_COLOR_HSL}};
    --input: {{SURFACE_COLOR_HSL}};
    --ring: {{PRIMARY_COLOR_HSL}};
    --radius: {{BORDER_RADIUS}};
    --chart-1: {{PRIMARY_COLOR_HSL}};
    --chart-2: {{SECONDARY_COLOR_HSL}};
    --chart-3: 0 0% 45%;
    --chart-4: 0 0% 60%;
    --chart-5: 0 0% 75%;

    /* Design system — shadows */
    --shadow-sm: {{SHADOW_SM}};
    --shadow-md: {{SHADOW_MD}};
    --shadow-lg: {{SHADOW_LG}};

    /* Design system — motion */
    --duration-micro: {{DURATION_MICRO}};
    --duration-page: {{DURATION_PAGE}};
    --ease-default: cubic-bezier({{ANIM_EASE}});
  }

  .dark {
    --background: 0 0% 7%;
    --foreground: 0 0% 95%;
    --card: 0 0% 10%;
    --card-foreground: 0 0% 95%;
    --popover: 0 0% 10%;
    --popover-foreground: 0 0% 95%;
    --primary: {{PRIMARY_COLOR_HSL}};
    --primary-foreground: 0 0% 100%;
    --secondary: {{SECONDARY_COLOR_HSL}};
    --secondary-foreground: 0 0% 100%;
    --muted: 0 0% 15%;
    --muted-foreground: 0 0% 75%; /* WCAG AA contrast — min 4.5:1 */
    --accent: 0 0% 15%;
    --accent-foreground: {{PRIMARY_COLOR_HSL}};
    --destructive: 0 62% 50%;
    --destructive-foreground: 0 0% 100%;
    --border: 0 0% 18%;
    --input: 0 0% 18%;
    --ring: {{PRIMARY_COLOR_HSL}};
    --chart-1: {{PRIMARY_COLOR_HSL}};
    --chart-2: {{SECONDARY_COLOR_HSL}};
    --chart-3: 0 0% 50%;
    --chart-4: 0 0% 55%;
    --chart-5: 0 0% 60%;

    /* Design system — shadows (dark mode) */
    --shadow-sm: {{SHADOW_SM}};
    --shadow-md: {{SHADOW_MD}};
    --shadow-lg: {{SHADOW_LG}};

    /* Design system — motion (same in dark) */
    --duration-micro: {{DURATION_MICRO}};
    --duration-page: {{DURATION_PAGE}};
    --ease-default: cubic-bezier({{ANIM_EASE}});
  }
}

@layer base {
  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground antialiased;
    font-family: var(--font-sans), system-ui, sans-serif;
    letter-spacing: 0.01em;
    line-height: 1.6;
  }
  h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.02em;
    font-family: var(--font-{{HEADING_FONT}}), Georgia, serif;
  }
  p {
    line-height: 1.75;
  }
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
}

/* ---- Respect reduced motion ---- */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ---- Subtle link underline ---- */
.link-underline {
  position: relative;
  display: inline-block;
}

.link-underline::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--secondary)));
  transition: width var(--duration-micro) var(--ease-default);
}

.link-underline:hover::after {
  width: 100%;
}

/* ---- Section label style ---- */
.section-label {
  @apply font-sans text-xs font-semibold uppercase tracking-[0.15em] text-primary mb-3;
}

/* ---- Stagger fade-in ---- */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY({{ANIM_DISTANCE}}px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fadeInUp var(--duration-page) var(--ease-default) forwards;
}

/* ---- Card hover — premium ---- */
.card-hover {
  @apply bg-card border border-border transition-all;
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  transition-duration: var(--duration-micro);
  transition-timing-function: var(--ease-default);
}

.card-hover:hover {
  @apply border-primary/20 -translate-y-1;
  box-shadow: var(--shadow-lg);
}

/* ---- Hero gradient — mesh ---- */
.hero-gradient {
  background:
    radial-gradient(ellipse 80% 50% at 80% 20%, hsl(var(--secondary) / 0.08), transparent),
    linear-gradient(135deg, hsl(var(--primary) / 0.1) 0%, hsl(var(--secondary) / 0.06) 50%, transparent 100%);
  position: relative;
  overflow: hidden;
}

.dark .hero-gradient {
  background:
    radial-gradient(ellipse 80% 50% at 80% 20%, hsl(var(--secondary) / 0.12), transparent),
    linear-gradient(135deg, hsl(var(--primary) / 0.15) 0%, hsl(var(--secondary) / 0.1) 50%, transparent 100%);
}

/* ---- Glass ---- */
.glass {
  @apply bg-white/80 backdrop-blur-2xl border border-white/90;
  box-shadow: var(--shadow-lg);
}

.dark .glass {
  @apply bg-white/10 border-white/20;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.08);
}

.glass-strong {
  @apply bg-white/90 backdrop-blur-2xl border border-border;
  box-shadow: var(--shadow-md);
}

.dark .glass-strong {
  @apply bg-white/10 border-white/10;
}

/* ---- Floating nav ---- */
.nav-pill {
  @apply bg-white/90 backdrop-blur-xl border border-border;
  box-shadow: var(--shadow-lg);
}

.dark .nav-pill {
  @apply bg-neutral-900/90 border-white/10;
}

/* ---- Stat counter ---- */
@keyframes countUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---- CTA gradient banner — premium ---- */
.cta-gradient {
  background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--primary) / 0.85) 50%, hsl(var(--secondary)) 100%);
  position: relative;
}

.cta-gradient::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.08) 0%, transparent 50%);
  pointer-events: none;
}

/* ---- Service icon wrapper ---- */
.service-icon {
  @apply w-12 h-12 flex items-center justify-center text-primary transition-all;
  border-radius: var(--radius);
  background: linear-gradient(135deg, hsl(var(--primary) / 0.12), hsl(var(--secondary) / 0.08));
  transition-duration: var(--duration-micro);
}

/* ---- Section divider ---- */
.section-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, hsl(var(--border)) 20%, hsl(var(--border)) 80%, transparent 100%);
}
